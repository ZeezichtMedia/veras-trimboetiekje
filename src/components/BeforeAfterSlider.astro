---
interface Props {
  beforeSrc?: string;
  afterSrc?: string;
  beforeLabel?: string;
  afterLabel?: string;
  alt?: string;
}

const {
  beforeSrc,
  afterSrc,
  beforeLabel = 'Voor',
  afterLabel = 'Na',
  alt = 'Voor en na trimbeurt',
} = Astro.props;

const id = `ba-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="ba-wrap" data-ba id={id} role="group" aria-label={alt}>
  {beforeSrc ? (
    <img class="ba-img" src={beforeSrc} alt={`${alt} — voor`} />
  ) : (
    <div class="ba-img" style="background:linear-gradient(135deg,#E5D5BE 0%,#CFA68C 100%);" aria-hidden="true">
      <div class="absolute inset-0 grid place-items-center">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.6" class="text-bark/35">
          <circle cx="7" cy="9" r="1.6" /><circle cx="12" cy="6.5" r="1.6" /><circle cx="17" cy="9" r="1.6" />
          <circle cx="5" cy="14" r="1.4" /><circle cx="19" cy="14" r="1.4" />
          <path d="M9 18.5c0-2.2 1.4-3.5 3-3.5s3 1.3 3 3.5c0 1.7-1.3 2.5-3 2.5s-3-.8-3-2.5z" />
        </svg>
      </div>
    </div>
  )}

  {afterSrc ? (
    <img class="ba-img ba-img-after" src={afterSrc} alt={`${alt} — na`} />
  ) : (
    <div class="ba-img ba-img-after" style="background:linear-gradient(135deg,#E2BFA9 0%,#B58569 100%);" aria-hidden="true">
      <div class="absolute inset-0 grid place-items-center">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.6" class="text-cream/55">
          <circle cx="7" cy="9" r="1.6" /><circle cx="12" cy="6.5" r="1.6" /><circle cx="17" cy="9" r="1.6" />
          <circle cx="5" cy="14" r="1.4" /><circle cx="19" cy="14" r="1.4" />
          <path d="M9 18.5c0-2.2 1.4-3.5 3-3.5s3 1.3 3 3.5c0 1.7-1.3 2.5-3 2.5s-3-.8-3-2.5z" />
          <path d="M3 21c2-2 5-3 9-3s7 1 9 3" />
        </svg>
      </div>
    </div>
  )}

  <span class="ba-label ba-label-before">{beforeLabel}</span>
  <span class="ba-label ba-label-after">{afterLabel}</span>

  <div class="ba-handle">
    <div class="ba-knob">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 6l-4 6 4 6" />
        <path d="M15 6l4 6-4 6" />
      </svg>
    </div>
  </div>

  <input
    type="range"
    min="0"
    max="100"
    value="50"
    class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize"
    aria-label={`${alt} — sleep om voor en na te vergelijken`}
    data-ba-input
  />
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((wrap) => {
    const input = wrap.querySelector<HTMLInputElement>('[data-ba-input]');
    if (!input) return;
    const set = (val: number) => {
      const pct = Math.max(0, Math.min(100, val));
      wrap.style.setProperty('--ba-pos', `${pct}%`);
    };
    set(Number(input.value));
    input.addEventListener('input', () => set(Number(input.value)));
  });
</script>
