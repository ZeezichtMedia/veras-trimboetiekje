---
import { navItems, site } from '../data/site';
import { services } from '../data/services';

const year = new Date().getFullYear();
---

<footer class="mt-32 bg-beige/40 border-t border-line/60">
  <div class="container-soft py-16 grid gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="font-display text-2xl">Vera's <span class="italic text-rose">Trimboetiekje</span></div>
      <p class="mt-4 text-sm leading-relaxed">
        Een rustige, liefdevolle trimsalon waar jouw hond met aandacht en in alle rust verzorgd wordt.
      </p>
      <div class="mt-5 flex items-center gap-3">
        <a href={site.instagram} aria-label="Instagram" target="_blank" rel="noopener"
          class="grid place-items-center w-9 h-9 rounded-full border border-line text-bark-soft hover:text-rose hover:border-rose/60 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" />
          </svg>
        </a>
        <a href={site.facebook} aria-label="Facebook" target="_blank" rel="noopener"
          class="grid place-items-center w-9 h-9 rounded-full border border-line text-bark-soft hover:text-rose hover:border-rose/60 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M13.5 21v-7.5h2.5l.5-3h-3V8.5c0-.9.3-1.5 1.6-1.5h1.5V4.2c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2H8v3h2.7V21h2.8z" />
          </svg>
        </a>
      </div>
    </div>

    <div>
      <h4 class="font-display text-lg mb-4">Menu</h4>
      <ul class="space-y-2 text-sm">
        {navItems.map((i) => (
          <li><a href={i.href} class="text-bark-soft hover:text-rose transition-colors">{i.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-display text-lg mb-4">Diensten</h4>
      <ul class="space-y-2 text-sm">
        {services.slice(0, 6).map((s) => (
          <li><a href={`/diensten#${s.slug}`} class="text-bark-soft hover:text-rose transition-colors">{s.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-display text-lg mb-4">Contact</h4>
      <address class="not-italic text-sm space-y-2 text-bark-soft">
        <div>{site.address.street}</div>
        <div>{site.address.postalCode} {site.address.city}</div>
        <div class="pt-2">
          <a href={site.whatsappUrl} class="hover:text-rose transition-colors" target="_blank" rel="noopener">
            WhatsApp · {site.whatsapp}
          </a>
        </div>
        <div class="pt-2 text-bark-mute">{site.hours}</div>
      </address>
      <a href={site.bookingUrl} class="btn-primary mt-5 text-sm">
        Plan een afspraak
      </a>
    </div>
  </div>

  <div class="border-t border-line/60">
    <div class="container-soft py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-bark-mute">
      <div>© {year} Vera's Trimboetiekje · Alle rechten voorbehouden</div>
      <div class="flex flex-col md:flex-row items-center gap-4">
        <a href="/voorwaarden" class="hover:text-rose transition-colors">Algemene voorwaarden</a>
        <span class="opacity-40 hidden md:inline">·</span>
        <a
          href="https://agensea.nl"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Website ontworpen en gebouwd door Agensea"
          class="agensea-credit group inline-flex items-center gap-3"
        >
          <span class="credit-label">Gebouwd door</span>
          <img
            src="/brand/agensea-logo.svg"
            alt="Agensea"
            width="140"
            height="37"
            class="credit-logo"
            loading="lazy"
            decoding="async"
          />
          <span class="credit-arrow" aria-hidden="true">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M17 7H8M17 7V16"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Agensea credit — premium signature ────────────────────
     Indigo (Agensea-brand) op licht beige Vera-footer: indigo
     contrasteert goed tegen het warme cream/beige palet zonder
     met de rose-accent kleur te concurreren. */
  .agensea-credit {
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .agensea-credit:focus-visible {
    outline: 2px solid #6366F1;
    outline-offset: 6px;
    border-radius: 2px;
  }

  .credit-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.6;
    transition: opacity 500ms cubic-bezier(0.16, 1, 0.3, 1);
    color: var(--color-bark-mute);
  }

  .credit-logo {
    height: 22px;
    width: auto;
    filter: brightness(0);
    opacity: 0.7;
    transition:
      opacity 500ms cubic-bezier(0.16, 1, 0.3, 1),
      filter 500ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: left center;
    will-change: filter, transform;
  }

  .credit-arrow {
    display: inline-flex;
    align-items: center;
    color: #6366F1;
    opacity: 0;
    transform: translate(-6px, 2px);
    transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .agensea-credit:hover .credit-label {
    opacity: 0.95;
  }

  .agensea-credit:hover .credit-logo {
    opacity: 1;
    /* Zwart logo blijft, alleen subtiele indigo halo. */
    filter:
      brightness(0)
      drop-shadow(0 0 6px rgba(99, 102, 241, 0.35))
      drop-shadow(0 0 14px rgba(99, 102, 241, 0.18));
    transform: scale(1.03);
  }

  .agensea-credit:hover .credit-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .credit-label,
    .credit-logo,
    .credit-arrow {
      transition: opacity 200ms ease;
    }
    .agensea-credit:hover .credit-logo {
      transform: none;
    }
  }
</style>
