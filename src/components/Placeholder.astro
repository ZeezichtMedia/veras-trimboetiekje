---
interface Props {
  src?: string;
  alt?: string;
  label?: string;
  ratio?: string;
  variant?: 'cream' | 'beige' | 'nude' | 'rose';
  rounded?: string;
  class?: string;
  width?: number;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt = '',
  label = 'Foto volgt',
  ratio = '4 / 3',
  variant = 'beige',
  rounded = 'var(--radius-soft)',
  class: className = '',
  width = 1200,
  loading = 'lazy',
} = Astro.props;

const bg = {
  cream: 'linear-gradient(135deg, #FAF6F0 0%, #F4ECE0 100%)',
  beige: 'linear-gradient(135deg, #EFE3D2 0%, #E5D5BE 100%)',
  nude: 'linear-gradient(135deg, #E2BFA9 0%, #C99B82 100%)',
  rose: 'linear-gradient(135deg, #E8C4B0 0%, #C99B82 100%)',
}[variant];

// Unsplash IDs krijgen automatisch optimalisatie-parameters; eigen URLs niet.
const buildSrc = (raw: string, w: number) => {
  if (raw.includes('images.unsplash.com')) {
    const sep = raw.includes('?') ? '&' : '?';
    return `${raw}${sep}w=${w}&q=80&auto=format&fit=crop`;
  }
  return raw;
};
---

<div
  class:list={['relative grid place-items-center overflow-hidden', className]}
  style={`aspect-ratio:${ratio}; background:${bg}; border-radius:${rounded};`}
>
  {src ? (
    <img
      src={buildSrc(src, width)}
      srcset={`${buildSrc(src, Math.round(width * 0.6))} ${Math.round(width * 0.6)}w, ${buildSrc(src, width)} ${width}w, ${buildSrc(src, Math.round(width * 1.5))} ${Math.round(width * 1.5)}w`}
      sizes="(max-width: 768px) 100vw, 50vw"
      alt={alt}
      loading={loading}
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />
  ) : (
    <>
      <svg
        width="80"
        height="80"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="0.7"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-bark/35"
        aria-hidden="true"
      >
        <circle cx="7" cy="9" r="1.6" />
        <circle cx="12" cy="6.5" r="1.6" />
        <circle cx="17" cy="9" r="1.6" />
        <circle cx="5" cy="14" r="1.4" />
        <circle cx="19" cy="14" r="1.4" />
        <path d="M9 18.5c0-2.2 1.4-3.5 3-3.5s3 1.3 3 3.5c0 1.7-1.3 2.5-3 2.5s-3-.8-3-2.5z" />
      </svg>
      <span class="absolute bottom-3 left-1/2 -translate-x-1/2 text-[10px] tracking-[0.22em] uppercase text-bark/45">
        {label}
      </span>
    </>
  )}
</div>
