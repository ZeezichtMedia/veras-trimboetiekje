---
interface Props {
  name: string;
  class?: string;
}
const { name, class: className = '' } = Astro.props;

const paths: Record<string, string> = {
  scissors:
    '<circle cx="6" cy="7" r="2.5"/><circle cx="6" cy="17" r="2.5"/><path d="M8 9l12 8M8 15l12-8"/>',
  leaf:
    '<path d="M5 19c8 0 14-6 14-14 0 0-3 0-6 1-3 1-7 4-8 7-1 3-.5 6 0 6z"/><path d="M5 19c2-3 4-5 7-7"/>',
  sparkle:
    '<path d="M12 4l1.5 4.5L18 10l-4.5 1.5L12 16l-1.5-4.5L6 10l4.5-1.5z"/><path d="M19 17l.6 1.7L21 19l-1.4.3L19 21l-.6-1.7L17 19l1.4-.3z"/>',
  droplet:
    '<path d="M12 3s-6 7-6 11a6 6 0 0012 0c0-4-6-11-6-11z"/>',
  paw:
    '<circle cx="7" cy="9" r="1.6"/><circle cx="12" cy="6.5" r="1.6"/><circle cx="17" cy="9" r="1.6"/><circle cx="5" cy="14" r="1.4"/><circle cx="19" cy="14" r="1.4"/><path d="M9 18.5c0-2.2 1.4-3.5 3-3.5s3 1.3 3 3.5c0 1.7-1.3 2.5-3 2.5s-3-.8-3-2.5z"/>',
  heart:
    '<path d="M12 20s-7-4.5-7-10a4 4 0 017-2.5A4 4 0 0119 10c0 5.5-7 10-7 10z"/>',
  star:
    '<path d="M12 4l2.4 5 5.6.8-4 4 1 5.6L12 16.8 7 19.4l1-5.6-4-4 5.6-.8z"/>',
};
---

<svg
  width="22"
  height="22"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={paths[name] ?? paths.paw}
/>
