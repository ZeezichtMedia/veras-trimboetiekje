---
import { navItems, site } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="sticky top-0 z-40 backdrop-blur bg-cream/85 border-b border-line/60">
  <div class="container-soft flex items-center justify-between gap-6 py-4">
    <a href="/" class="flex items-center gap-2 group" aria-label="Home — {site.name}">
      <span class="grid place-items-center w-9 h-9 rounded-full bg-nude/40 text-bark transition-colors group-hover:bg-nude/60">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="7" cy="9" r="2" />
          <circle cx="12" cy="6.5" r="2" />
          <circle cx="17" cy="9" r="2" />
          <circle cx="5" cy="14" r="1.6" />
          <circle cx="19" cy="14" r="1.6" />
          <path d="M9 18c0-2.2 1.4-3.5 3-3.5s3 1.3 3 3.5c0 1.7-1.3 2.5-3 2.5s-3-.8-3-2.5z" />
        </svg>
      </span>
      <span class="font-display text-lg leading-none">
        <span class="block tracking-tight">Vera's</span>
        <span class="block text-rose italic text-sm leading-none -mt-0.5">Trimboetiekje</span>
      </span>
    </a>

    <nav aria-label="Hoofdmenu" class="hidden lg:flex items-center gap-7">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm transition-colors hover:text-rose',
            isActive(item.href) ? 'text-rose' : 'text-bark-soft',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a href={site.bookingUrl} class="btn-primary text-sm">
        Plan een afspraak
      </a>
    </div>

    <button
      type="button"
      class="lg:hidden grid place-items-center w-10 h-10 rounded-full border border-line text-bark"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-line/60 bg-cream"
    data-menu
  >
    <nav aria-label="Mobielmenu" class="container-soft py-4 flex flex-col gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'py-3 px-2 rounded-lg text-base transition-colors',
            isActive(item.href) ? 'text-rose bg-nude/15' : 'text-bark hover:bg-beige/40',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href={site.bookingUrl} class="btn-primary mt-3 w-full">
        Plan een afspraak
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
