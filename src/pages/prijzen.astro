---
import Layout from '../layouts/Layout.astro';
import { priceGroups, surcharge } from '../data/prices';
import { site } from '../data/site';
---

<Layout
  title="Prijzen"
  description="Tarieven van Vera's Trimboetiekje — vanaf-prijzen voor complete trimbehandelingen, tussenbeurten, puppy wenbeurten en extra verzorging."
>
  <section class="relative overflow-hidden pt-16 pb-16">
    <div class="soft-blob bg-rose/20 w-[400px] h-[400px] -top-24 -left-20"></div>
    <div class="container-soft relative">
      <span class="eyebrow">Prijzen</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl leading-tight max-w-3xl">
        Eerlijke tarieven, afgestemd op <span class="italic text-rose">jouw hond</span>.
      </h1>
      <p class="mt-6 max-w-2xl text-lg">
        De prijs van een behandeling hangt af van de tijd, vacht en zorg die nodig zijn voor jouw hond. Iedere hond is anders — daarom zijn onderstaande prijzen vanaf-prijzen.
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-soft grid md:grid-cols-2 gap-6">
      {priceGroups.map((g) => (
        <div class="reveal bg-cream rounded-[24px] p-7 md:p-8 border border-line/60 hover:border-rose/40 transition-colors flex flex-col">
          <h2 class="font-display text-xl md:text-2xl">{g.title}</h2>
          <p class="mt-3 text-sm">{g.description}</p>
          <ul class="mt-6 space-y-3 text-sm flex-1">
            {g.items.map((it) => (
              <li class="flex items-baseline justify-between gap-4 border-b border-line/60 pb-3 last:border-b-0 last:pb-0">
                <span class="text-bark">{it.label}</span>
                <span class="font-display text-lg text-rose tabular-nums">{it.price}</span>
              </li>
            ))}
          </ul>
          {g.note && (
            <p class="mt-5 text-xs text-bark-mute italic">{g.note}</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="pb-24">
    <div class="container-soft">
      <div class="bg-beige/40 rounded-[28px] p-8 md:p-10 border border-line/60 grid md:grid-cols-12 gap-6 items-center">
        <div class="md:col-span-1 grid place-items-center">
          <span class="grid place-items-center w-12 h-12 rounded-full bg-nude/40 text-rose">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round"/></svg>
          </span>
        </div>
        <div class="md:col-span-11">
          <h3 class="font-display text-xl">Toeslag bij extra tijd</h3>
          <p class="mt-2 text-sm">{surcharge.text}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-soft">
      <div class="bg-cream rounded-[28px] p-10 md:p-14 text-center max-w-3xl mx-auto border border-line/60">
        <h2 class="font-display text-2xl md:text-3xl">
          Nog vragen over de <span class="italic text-rose">prijs</span>?
        </h2>
        <p class="mt-4 max-w-xl mx-auto">
          Neem gerust contact op of plan direct een afspraak in de agenda.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href={site.bookingUrl} class="btn-primary">Plan een afspraak</a>
          <a href="/contact" class="btn-secondary">Stel een vraag</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
