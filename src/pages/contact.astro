---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout
  title="Contact"
  description="Contactgegevens van Vera's Trimboetiekje in Berghem — adres, WhatsApp, social media en online afspraak maken."
>
  <section class="relative overflow-hidden pt-16 pb-16">
    <div class="soft-blob bg-nude/30 w-[400px] h-[400px] -top-24 -left-20"></div>
    <div class="container-soft relative max-w-3xl">
      <span class="eyebrow">Contact</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl leading-tight">
        Een vraag of <span class="italic text-rose">twijfel</span>?
      </h1>
      <p class="mt-6 text-lg">
        Heb je een vraag of twijfel je welke behandeling het beste past bij jouw hond? Neem gerust contact op — ik denk graag met je mee.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-soft grid lg:grid-cols-12 gap-8">
      <!-- Contact details -->
      <div class="lg:col-span-5 space-y-4">
        <a href={site.whatsappUrl} target="_blank" rel="noopener"
          class="reveal block bg-cream rounded-[24px] p-7 border border-line/60 hover:border-rose/40 hover:shadow-soft transition-all">
          <div class="flex items-start gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-[#25D366]/15 text-[#25D366]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11.7 11.7 0 0012 0C5.4 0 0 5.4 0 12c0 2.1.5 4.1 1.6 5.9L0 24l6.3-1.6A11.9 11.9 0 0012 24c6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.5-8.5z"/></svg>
            </span>
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-bark-mute">WhatsApp</div>
              <div class="font-display text-2xl mt-1 text-bark">{site.whatsapp}</div>
              <div class="text-sm mt-1 text-bark-soft">Snelste manier om iets te vragen.</div>
            </div>
          </div>
        </a>

        <div class="reveal bg-cream rounded-[24px] p-7 border border-line/60">
          <div class="flex items-start gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-nude/30 text-rose">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s7-6.5 7-12a7 7 0 10-14 0c0 5.5 7 12 7 12z"/><circle cx="12" cy="10" r="2.5"/></svg>
            </span>
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-bark-mute">Adres</div>
              <address class="not-italic mt-1">
                <div class="text-bark font-medium">{site.address.street}</div>
                <div class="text-bark-soft">{site.address.postalCode} {site.address.city}</div>
              </address>
              <a
                href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(site.address.street + ', ' + site.address.postalCode + ' ' + site.address.city)}`}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1 mt-3 text-rose hover:text-rose-dark text-sm"
              >
                Routebeschrijving
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="reveal bg-cream rounded-[24px] p-7 border border-line/60">
          <div class="flex items-start gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-nude/30 text-rose">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round"/></svg>
            </span>
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-bark-mute">Beschikbaarheid</div>
              <div class="text-bark font-medium mt-1">Uitsluitend op afspraak</div>
            </div>
          </div>
        </div>

        <div class="reveal bg-cream rounded-[24px] p-7 border border-line/60">
          <div class="text-xs uppercase tracking-[0.2em] text-bark-mute">Social</div>
          <div class="mt-3 flex flex-wrap gap-3">
            <a href={site.instagram} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-line text-sm hover:border-rose/60 hover:text-rose transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/></svg>
              {site.instagramHandle}
            </a>
            <a href={site.facebook} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-line text-sm hover:border-rose/60 hover:text-rose transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-7.5h2.5l.5-3h-3V8.5c0-.9.3-1.5 1.6-1.5h1.5V4.2c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2H8v3h2.7V21h2.8z"/></svg>
              {site.facebookHandle}
            </a>
          </div>
        </div>
      </div>

      <!-- Map + booking -->
      <div class="lg:col-span-7 space-y-6">
        <div class="reveal rounded-[24px] overflow-hidden border border-line/60 bg-cream">
          <iframe
            src={site.mapsEmbed}
            width="100%"
            height="380"
            style="border:0; display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Locatie Vera's Trimboetiekje"
            allowfullscreen
          ></iframe>
        </div>

        <div class="reveal bg-gradient-to-br from-nude via-rose to-rose-dark rounded-[24px] p-8 text-cream relative overflow-hidden">
          <div class="soft-blob bg-cream/30 w-[200px] h-[200px] -top-12 -right-12"></div>
          <div class="relative">
            <h2 class="font-display text-2xl md:text-3xl">
              Klaar om een <span class="italic">afspraak</span> te maken?
            </h2>
            <p class="mt-3 text-cream/85 max-w-md">
              Plan eenvoudig online een afspraak in de agenda.
            </p>
            <a href={site.bookingUrl}
              class="inline-flex items-center gap-2 mt-5 bg-cream text-bark px-6 py-3 rounded-full font-medium hover:bg-cream/90 transition-colors">
              Plan een afspraak
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-soft">
      <p class="text-center max-w-xl mx-auto text-bark-mute italic">
        Ik help je graag verder en hoop jou en jouw hond binnenkort te mogen verwelkomen in mijn salon.
      </p>
    </div>
  </section>
</Layout>
