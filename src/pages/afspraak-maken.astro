---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout
  title="Afspraak maken"
  description="Plan een afspraak in de online agenda van Vera's Trimboetiekje — kies dienst, dag en tijd."
>
  <section class="relative overflow-hidden pt-12 pb-24 min-h-[80vh]">
    <div class="soft-blob bg-rose/20 w-[460px] h-[460px] -top-32 -right-20"></div>
    <div class="soft-blob bg-nude/30 w-[380px] h-[380px] bottom-10 -left-20"></div>

    <div class="container-soft relative">
      <div class="max-w-3xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-bark-soft hover:text-rose transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Terug naar home
        </a>

        <div class="mt-6 bg-cream rounded-[28px] border border-line/70 shadow-card overflow-hidden">
          <div class="px-7 md:px-10 pt-8 pb-6 border-b border-line/60 bg-beige/30">
            <span class="eyebrow">Online agenda</span>
            <h1 class="mt-3 font-display text-3xl md:text-4xl leading-tight">
              Plan een <span class="italic text-rose">afspraak</span>
            </h1>
            <p class="mt-3 text-sm text-bark-soft max-w-xl">
              Kies de behandeling, een dag en een tijdstip. Je krijgt direct een bevestiging.
            </p>
          </div>

          <div class="px-4 md:px-6 py-6">
            <!-- Salonized booking widget — inline, NL, hoogte 700px -->
            <div
              class="salonized-booking"
              data-company="685TLUuhbERw1WLVd9KyW8jr"
              data-color="#d0c0af"
              data-language="nl"
              data-height="700"
              data-inline="true"
              data-outline="shadow"
            ></div>
          </div>
        </div>

        <p class="mt-6 text-center text-xs text-bark-mute">
          Liever bellen of appen? <a href={site.whatsappUrl} target="_blank" rel="noopener" class="text-rose hover:underline">{site.whatsapp}</a>
        </p>
      </div>
    </div>
  </section>

  <script is:inline src="https://static-widget.salonized.com/loader.js"></script>
</Layout>
