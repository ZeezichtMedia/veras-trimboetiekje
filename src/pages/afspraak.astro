---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const steps = [
  { num: '01', title: 'Kies een dienst', text: 'Selecteer in de agenda de behandeling die past bij jouw hond.' },
  { num: '02', title: 'Plan datum & tijd', text: 'Kies een vrij moment in de online agenda — dag of avond.' },
  { num: '03', title: 'Bevestig je afspraak', text: 'Vul je gegevens in, ga akkoord met de voorwaarden en klaar — je krijgt een bevestiging per e-mail.' },
];
---

<Layout
  title="Afspraak maken"
  description="Plan eenvoudig een afspraak bij Vera's Trimboetiekje via de online agenda."
>
  <section class="relative overflow-hidden pt-16 pb-16">
    <div class="soft-blob bg-rose/25 w-[420px] h-[420px] -top-32 right-0"></div>
    <div class="container-soft relative max-w-4xl">
      <span class="eyebrow">Afspraak maken</span>
      <h1 class="mt-4 font-display text-4xl md:text-5xl lg:text-6xl leading-tight">
        Eenvoudig online een <span class="italic text-rose">afspraak</span> plannen.
      </h1>
      <p class="mt-6 max-w-2xl text-lg">
        Plan jouw afspraak in de online agenda — zo zie je direct welke momenten beschikbaar zijn. Heb je liever persoonlijk contact? Stuur me dan een berichtje via WhatsApp.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={site.bookingUrl} class="btn-primary">
          Open de online agenda
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={site.whatsappUrl} target="_blank" rel="noopener" class="btn-secondary">WhatsApp Vera</a>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-soft">
      <div class="grid md:grid-cols-3 gap-5">
        {steps.map((s) => (
          <div class="reveal bg-cream rounded-[24px] p-7 border border-line/60">
            <span class="font-display text-3xl text-rose">{s.num}</span>
            <h3 class="mt-3 font-display text-xl">{s.title}</h3>
            <p class="mt-2 text-sm">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-soft">
      <div class="bg-beige/40 rounded-[28px] p-8 md:p-12 border border-line/60 grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7">
          <h2 class="font-display text-2xl md:text-3xl">
            Goed om te <span class="italic text-rose">weten</span>
          </h2>
          <ul class="mt-5 space-y-3 text-sm">
            <li class="flex gap-3">
              <span class="text-rose mt-1">·</span>
              <span>Ik werk uitsluitend op afspraak.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-rose mt-1">·</span>
              <span>Bij nieuwe klanten vraag ik een aanbetaling van 10% van het afgesproken tarief.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-rose mt-1">·</span>
              <span>Annuleren kan kosteloos tot 24 uur voor de afspraak.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-rose mt-1">·</span>
              <span>Bij het maken van een afspraak ga je akkoord met de <a href="/voorwaarden" class="text-rose hover:underline">algemene voorwaarden</a>.</span>
            </li>
          </ul>
        </div>
        <div class="lg:col-span-5">
          <div class="bg-cream rounded-2xl p-6 shadow-soft">
            <div class="text-xs uppercase tracking-[0.2em] text-bark-mute">Liever bellen of appen?</div>
            <a href={site.whatsappUrl} target="_blank" rel="noopener" class="block mt-3 font-display text-2xl text-rose">
              {site.whatsapp}
            </a>
            <p class="mt-2 text-sm">Stuur me een berichtje en ik denk graag met je mee over de juiste behandeling.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
