---
import Layout from '../layouts/Layout.astro';
import Placeholder from '../components/Placeholder.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { services } from '../data/services';
import { site } from '../data/site';
import { photos } from '../data/images';

const pillars = [
  { icon: 'leaf', title: 'Rust voorop', text: 'Geen drukte, geen haast — een rustige omgeving waarin jouw hond stap voor stap kan wennen.' },
  { icon: 'heart', title: 'Tijd voor jouw hond', text: 'Ik neem de tijd voor iedere behandeling. Geen haast, geen druk — alles op een tempo waarin jouw hond zich prettig voelt.' },
  { icon: 'sparkle', title: 'Met aandacht', text: 'Ik kijk naar wat jouw hond nodig heeft, qua vacht én qua gedrag.' },
  { icon: 'paw', title: 'Welzijn eerst', text: 'Een mooi resultaat is mooi, maar een ontspannen hond is het mooiste resultaat.' },
  { icon: 'star', title: 'Boetiek-gevoel', text: 'Een lieve, persoonlijke salon — alsof je hond bij familie op visite gaat.' },
];
---

<Layout
  title="Hondentrimsalon in Berghem"
  description="Vera's Trimboetiekje — een rustige, liefdevolle trimsalon in Berghem. Met tijd en aandacht voor de vacht én het welzijn van jouw hond."
>
  <!-- ── HERO ───────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <div class="soft-blob bg-nude/40 w-[420px] h-[420px] -top-32 -left-24"></div>
    <div class="soft-blob bg-rose/25 w-[360px] h-[360px] top-32 right-0"></div>

    <div class="container-soft relative grid lg:grid-cols-2 gap-14 items-center pt-16 pb-24 lg:pt-24 lg:pb-32">
      <div class="reveal">
        <span class="eyebrow">Hondentrimsalon · Berghem</span>
        <h1 class="mt-5 font-display text-5xl md:text-6xl lg:text-7xl leading-[1.05]">
          Met liefde en
          <span class="italic text-rose">aandacht</span>
          voor jouw hond.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed">
          Een rustige, liefdevolle trimsalon waar jouw hond met volledige aandacht en in alle rust verzorgd wordt. Geen drukte, geen stress — alleen tijd voor jou en je hond.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.bookingUrl} class="btn-primary">
            Plan een afspraak
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/diensten" class="btn-secondary">Bekijk diensten</a>
        </div>

        <div class="mt-10 flex items-center gap-5 text-sm text-bark-mute">
          <div class="flex -space-x-2">
            <a
              href={site.instagram}
              target="_blank"
              rel="noopener"
              aria-label={`Instagram — ${site.instagramHandle}`}
              class="relative grid place-items-center w-9 h-9 rounded-full border-2 border-cream bg-nude text-cream hover:z-10 hover:scale-110 transition-transform"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none" />
              </svg>
            </a>
            <a
              href={site.facebook}
              target="_blank"
              rel="noopener"
              aria-label={`Facebook — ${site.facebookHandle}`}
              class="relative grid place-items-center w-9 h-9 rounded-full border-2 border-cream bg-rose text-cream hover:z-10 hover:scale-110 transition-transform"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13.5 21v-7.5h2.5l.5-3h-3V8.5c0-.9.3-1.5 1.6-1.5h1.5V4.2c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2H8v3h2.7V21h2.8z" />
              </svg>
            </a>
            <a
              href={site.whatsappUrl}
              target="_blank"
              rel="noopener"
              aria-label={`WhatsApp — ${site.whatsapp}`}
              class="relative grid place-items-center w-9 h-9 rounded-full border-2 border-cream bg-rose-dark text-cream hover:z-10 hover:scale-110 transition-transform"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.5 3.5A11.7 11.7 0 0012 0C5.4 0 0 5.4 0 12c0 2.1.5 4.1 1.6 5.9L0 24l6.3-1.6A11.9 11.9 0 0012 24c6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.5-8.5zM12 21.8a9.8 9.8 0 01-5-1.4l-.4-.2-3.7 1 1-3.6-.2-.4A9.8 9.8 0 012.2 12C2.2 6.6 6.6 2.2 12 2.2S21.8 6.6 21.8 12 17.4 21.8 12 21.8z"/>
              </svg>
            </a>
          </div>
          <span>Werkt uitsluitend op afspraak</span>
        </div>
      </div>

      <div class="reveal relative">
        <div class="absolute -inset-4 bg-nude/20 blur-2xl rounded-[40px]"></div>
        <Placeholder
          src={photos.hero.src}
          alt={photos.hero.alt}
          variant="beige"
          ratio="4 / 5"
          rounded="32px"
          width={1100}
          loading="eager"
          class="relative shadow-card"
        />
        <div class="absolute -bottom-6 -left-6 bg-cream rounded-2xl shadow-card p-5 max-w-[220px]">
          <div class="flex items-center gap-2 text-rose">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-7-10a4 4 0 017-2.5A4 4 0 0119 11c0 5.5-7 10-7 10z"/></svg>
            <span class="text-xs uppercase tracking-[0.18em] font-medium">Met liefde</span>
          </div>
          <p class="mt-2 text-sm text-bark">"Een ontspannen hond is het mooiste resultaat."</p>
          <p class="mt-1 text-xs text-bark-mute">— Vera</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PILLARS ────────────────────────────────────────── -->
  <section class="py-20 bg-cream-dark/50 border-y border-line/40">
    <div class="container-soft">
      <div class="max-w-2xl">
        <span class="eyebrow">Waarom Vera's Trimboetiekje</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-display">
          Iedere hond verdient een behandeling die past bij <span class="italic text-rose">zijn of haar</span> vacht, gedrag en behoeften.
        </h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {pillars.map((p) => (
          <div class="reveal bg-cream rounded-2xl p-6 border border-line/60 hover:border-rose/40 transition-colors">
            <span class="grid place-items-center w-11 h-11 rounded-full bg-nude/30 text-rose mb-4">
              <ServiceIcon name={p.icon} />
            </span>
            <h3 class="font-display text-lg">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BEFORE / AFTER ─────────────────────────────────── -->
  <section class="py-24">
    <div class="container-soft">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="eyebrow">Voor &amp; na</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-display leading-tight">
            Sleep en zie het <span class="italic text-rose">verschil</span>.
          </h2>
          <p class="mt-5 max-w-md">
            Iedere trimbeurt is anders. Soms een kleine opfrissing, soms een complete transformatie — altijd met aandacht voor de vacht én voor het comfort van jouw hond.
          </p>
          <div class="mt-7 flex items-center gap-3 text-sm text-bark-mute">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
              <path d="M9 6l-4 6 4 6M15 6l4 6-4 6"/>
            </svg>
            <span>Sleep de schuif om voor en na te vergelijken</span>
          </div>
        </div>

        <div class="reveal">
          <BeforeAfterSlider
            beforeSrc={photos.beforeBefore.src}
            afterSrc={photos.beforeAfter.src}
            alt="Voor en na trimbeurt bij Vera's Trimboetiekje"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT PREVIEW ──────────────────────────────────── -->
  <section class="py-24 bg-beige/30">
    <div class="container-soft grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 reveal">
        <Placeholder
          src={photos.about.src}
          alt={photos.about.alt}
          variant="nude"
          ratio="4 / 5"
          rounded="28px"
          width={900}
          class="shadow-card"
        />
      </div>
      <div class="lg:col-span-7 reveal">
        <span class="eyebrow">Even voorstellen</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-display">
          Hoi, ik ben <span class="italic text-rose">Vera</span>.
        </h2>
        <div class="mt-5 space-y-4 max-w-xl">
          <p>
            Mijn liefde voor honden is altijd al aanwezig geweest, maar werd pas écht versterkt toen mijn twee cockapoos Beer en Billy in mijn leven kwamen. Met hun vrolijke karakter en zachte vacht hebben zij mij laten zien hoe belangrijk goede vachtverzorging is — maar vooral hoe belangrijk het is dat een hond zich veilig voelt.
          </p>
          <p>
            In mijn salon neem ik de tijd, zonder haast en met volledige aandacht voor jouw hond. Geen drukte, geen stress — een rustige omgeving waarin jouw hond stap voor stap kan wennen.
          </p>
        </div>
        <a href="/over-mij" class="inline-flex items-center gap-2 mt-7 text-rose hover:text-rose-dark transition-colors text-sm font-medium">
          Lees meer over mij
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICES ───────────────────────────────────────── -->
  <section class="py-24">
    <div class="container-soft">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div class="max-w-xl">
          <span class="eyebrow">Diensten</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-display">
            Behandelingen op maat, <span class="italic text-rose">altijd in alle rust</span>.
          </h2>
        </div>
        <a href="/diensten" class="btn-secondary self-start md:self-auto">Alle diensten</a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.slice(0, 6).map((s) => (
          <a
            href={`/diensten#${s.slug}`}
            class="reveal group bg-cream rounded-2xl p-6 border border-line/60 hover:border-rose/40 hover:shadow-soft transition-all flex flex-col"
          >
            <span class="grid place-items-center w-12 h-12 rounded-full bg-beige/60 text-rose mb-5 group-hover:bg-nude/40 transition-colors">
              <ServiceIcon name={s.icon} />
            </span>
            <h3 class="font-display text-xl">{s.title}</h3>
            <p class="mt-2 text-sm flex-1">{s.short}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-rose text-sm font-medium">
              Ontdek meer
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="group-hover:translate-x-0.5 transition-transform">
                <path d="M5 12h14M13 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────── -->
  <section class="py-24">
    <div class="container-soft">
      <div class="relative overflow-hidden rounded-[32px] bg-gradient-to-br from-nude via-rose to-rose-dark text-cream p-10 md:p-16">
        <div class="soft-blob bg-cream/30 w-[280px] h-[280px] -top-20 -right-20"></div>
        <div class="relative max-w-2xl">
          <h2 class="font-display text-3xl md:text-5xl text-cream leading-tight">
            Klaar voor een rustige, <span class="italic">liefdevolle</span> trimbeurt?
          </h2>
          <p class="mt-5 text-cream/85 text-lg max-w-lg">
            Plan eenvoudig online een afspraak in de agenda, of stuur me een berichtje via WhatsApp — ik denk graag met je mee.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={site.bookingUrl}
              class="inline-flex items-center gap-2 bg-cream text-bark px-6 py-3 rounded-full font-medium hover:bg-cream/90 transition-colors">
              Plan een afspraak
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={site.whatsappUrl} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 border border-cream/40 text-cream px-6 py-3 rounded-full font-medium hover:bg-cream/10 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11.7 11.7 0 0012 0C5.4 0 0 5.4 0 12c0 2.1.5 4.1 1.6 5.9L0 24l6.3-1.6A11.9 11.9 0 0012 24c6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.5-8.5zM12 21.8a9.8 9.8 0 01-5-1.4l-.4-.2-3.7 1 1-3.6-.2-.4A9.8 9.8 0 012.2 12C2.2 6.6 6.6 2.2 12 2.2S21.8 6.6 21.8 12 17.4 21.8 12 21.8z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
